# Required backend configuration
# Copy this file to an untracked .env.local for local development, or export
# the variables in your shell before starting Vite.
# Never commit real Supabase runtime values.
# The app runs in backend-required mode and will block startup if these values
# are missing or left as placeholders.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=<your-supabase-anon-key>

# Optional debug logging
VITE_DEBUG=false
